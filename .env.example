# Copy to .env (gitignored) and fill in. The API loads this at startup.
GEMINI_API_KEY=
# Optional, defaults to gemini-2.5-flash
GEMINI_MODEL=

# Social publishing (Sprint 17): Reddit OAuth app credentials. Create the app
# at https://www.reddit.com/prefs/apps (type "web app", redirect uri
# http://localhost:3050/oauth/callback) — the Reddit card on the Integrations
# page becomes connectable once these are set.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
