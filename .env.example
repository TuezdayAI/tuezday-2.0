# Copy to .env (gitignored) and fill in. The API loads this at startup.
GEMINI_API_KEY=
# Optional, defaults to gemini-2.5-flash
GEMINI_MODEL=

# LLM provider flexibility (Sprint 41 Part 1)
# Primary provider: gemini (default) | openrouter. The other becomes automatic
# fallback if its key is set — a provider outage degrades instead of failing.
LLM_PROVIDER=
OPENROUTER_API_KEY=
# Optional, defaults to google/gemini-2.5-flash (same family, different pipe)
OPENROUTER_MODEL=

# Google Auth (Sprint 36): Create an OAuth 2.0 Web application at console.cloud.google.com
# Set Authorized redirect URIs to: http://localhost:3000/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social publishing (Sprint 17): Reddit OAuth app credentials. Create the app
# at https://www.reddit.com/prefs/apps (type "web app", redirect uri
# http://localhost:3050/oauth/callback) — the Reddit card on the Integrations
# page becomes connectable once these are set.
# Connected discovery (Sprint 46) also needs the `read` scope; it is requested
# automatically, but Reddit accounts connected before Sprint 46 must be
# disconnected/reconnected once to pick it up.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Connect social (Sprint 25): LinkedIn / X / Instagram OAuth apps. Each card on
# the Integrations page stays "needs OAuth app" until BOTH of its vars are set.
# For every app, register the Nango callback URL
# http://localhost:3050/oauth/callback as the redirect/callback URI.
#
# LinkedIn — https://www.linkedin.com/developers/apps : add the "Sign In with
# LinkedIn using OpenID Connect" + "Share on LinkedIn" products (scopes:
# openid, profile, email, w_member_social).
# Connected discovery (Sprint 46) additionally requests r_member_social to
# read member posts — LinkedIn grants it only through Community Management API
# app approval, so without it LinkedIn discovery sources show a clear
# "permission required" error while the rest of discovery keeps running.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# X (Twitter) — https://developer.x.com : an OAuth 2.0 app with tweet.read,
# tweet.write, users.read, dm.read, dm.write, offline.access. Use the OAuth 2.0
# Client ID / Client Secret (not the API key/secret).
# Connected discovery (Sprint 46) also requests list.read for X list-timeline
# sources; X accounts connected before Sprint 46 must be
# disconnected/reconnected once to pick it up. X search/timeline reading works
# within your X API plan's rate limits — sources back off automatically on 429.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Instagram — a Facebook app (https://developers.facebook.com/apps) with the
# Instagram Graph API. Publishing needs an Instagram Business/Creator account
# linked to a Facebook Page and instagram_content_publish granted via App
# Review. These are the FACEBOOK app's id/secret.
# Connected discovery (Sprint 46): competitor (business-discovery) and hashtag
# sources need a professional IG account plus Meta App Review approval
# (instagram_basic and Public Content Access for hashtags). Without approval
# those sources show "permission required" instead of silently returning
# nothing.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Users, teams & auth (Sprint 19): shared secret that lets the background
# worker call the API as the "system" actor across all workspaces. Set the
# same value for both the API and the worker process. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TUEZDAY_WORKER_TOKEN=

# Product analytics (Sprint 35): PostHog. The API backend key (POSTHOG_API_KEY)
# and the web client key (NEXT_PUBLIC_POSTHOG_KEY) should typically be the same
# project key. POSTHOG_HOST is optional (defaults to US cloud).
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Billing & Stripe (Sprint 37): Add these vars for checkout and webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# Notifications & Approvals (Sprint 39): Telegram bot and action tokens.
# TELEGRAM_BOT_TOKEN: Create a bot via @BotFather on Telegram.
# NOTIFY_SIGNING_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# APP_BASE_URL: For public approve/reject links and telegram webhooks.
TELEGRAM_BOT_TOKEN=
NOTIFY_SIGNING_SECRET=
APP_BASE_URL=http://localhost:3000

# MCP Server (Sprint 40): API URL and API key to connect to the main API.
TUEZDAY_API_URL=http://localhost:3000/api/v1
TUEZDAY_API_KEY=

# Design layer (Sprint 41 Part 3): self-hosted Open Design daemon (template
# authoring only — never on the per-post render path). Bring it up with
# `npm run opendesign:up`; OD_API_TOKEN below must match the daemon's.
OPEN_DESIGN_BASE_URL=http://localhost:4000
OPEN_DESIGN_API_TOKEN=
# S3-compatible asset storage (R2/B2/S3/MinIO) for rendered slide/ad PNGs —
# Instagram and Meta need publicly fetchable URLs.
ASSET_STORAGE_ENDPOINT=
ASSET_STORAGE_BUCKET=
ASSET_STORAGE_ACCESS_KEY=
ASSET_STORAGE_SECRET_KEY=
ASSET_STORAGE_PUBLIC_BASE_URL=
# Optional; SigV4 region, defaults to "auto" (fine for R2/MinIO).
ASSET_STORAGE_REGION=
